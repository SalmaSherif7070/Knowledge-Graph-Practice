# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# LLM provider: gemini | groq
LLM_PROVIDER=gemini

# Gemini — add GEMINI_API_KEY_2, GEMINI_API_KEY_3, etc. as fallbacks
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_MODEL=gemini-2.0-flash

# Groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Jina embeddings
JINA_API_KEY=
EMBEDDING_MODEL=jina-embeddings-v3

# Conflict detection tuning
SIMILARITY_THRESHOLD=0.60
TOP_K_CANDIDATES=20
