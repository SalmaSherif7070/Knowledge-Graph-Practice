# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j

# Gemini — add GEMINI_API_KEY_2, GEMINI_API_KEY_3, etc. as fallbacks
GEMINI_API_KEY=
GEMINI_API_KEY_2=
GEMINI_API_KEY_3=
GEMINI_MODEL=gemini-2.0-flash

# Jina embeddings
JINA_API_KEY=
EMBEDDING_MODEL=jina-embeddings-v3

# Conflict detection tuning
SIMILARITY_THRESHOLD=0.60   # cosine similarity cutoff (0.0–1.0)
TOP_K_CANDIDATES=20          # how many candidates to check per new rule
